FROM golang:1.22-alpine AS build

WORKDIR /src

COPY agent/go.mod agent/go.sum ./
RUN go mod download

COPY agent/ ./

RUN CGO_ENABLED=0 GOOS=linux GOARCH=amd64 go build -o /booking-agent .

FROM alpine:3.20

RUN apk add --no-cache ca-certificates tzdata

COPY --from=build /booking-agent /usr/local/bin/booking-agent

EXPOSE 9000

CMD ["/usr/local/bin/booking-agent"]
